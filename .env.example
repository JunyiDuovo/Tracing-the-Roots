# 推荐使用下面分项配置（中文密码、避免一行 URL 编码错误；.env 请保存为 UTF-8）
GENEALOGY_DB_USER=postgres
GENEALOGY_DB_PASSWORD=postgres
GENEALOGY_DB_HOST=127.0.0.1
GENEALOGY_DB_PORT=5432
GENEALOGY_DB_NAME=genealogy_db

# 若未设置 GENEALOGY_DB_HOST，才会使用下面一行式连接串（密码请仅用英文/数字较稳妥）
# GENEALOGY_DATABASE_URL=postgresql+psycopg2://postgres:postgres@127.0.0.1:5432/genealogy_db

SECRET_KEY=change-me-in-production
